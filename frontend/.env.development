# Set to the deployed API Gateway URL after `terraform apply`. The Terraform
# output `notification_api_endpoint` provides the value. Example:
# VITE_API_BASE_URL=https://abc123.execute-api.us-east-1.amazonaws.com
VITE_API_BASE_URL=https://kw008a51u6.execute-api.us-east-1.amazonaws.com

# Auth API Gateway URL. Terraform output `auth_api_endpoint` provides the value.
VITE_AUTH_API_BASE_URL=https://uz58tbk6j9.execute-api.us-east-1.amazonaws.com
